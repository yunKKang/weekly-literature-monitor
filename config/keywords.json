    "method_bonus": 3,
    "method_bonus_cap": 6,
    "policy_bonus": 2,
    "policy_bonus_cap": 6,
    "multi_pipeline_bonus": 5,
    "high_priority_threshold": 20,
    "medium_priority_threshold": 12,
    "consistency_check_enabled": true
  },

